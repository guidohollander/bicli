{
  "name": "bicli",
  "version": "0.1.0",
  "private": true,
  "description": "Rule-based Be Informed BIXML syntax validator",
  "type": "module",
  "bin": {
    "bicli": "./bin/bicli.js",
    "bicli-dev": "./bin/bicli-dev.js",
    "bicli-mcp": "./bin/bicli-mcp.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:win-exe": "powershell -ExecutionPolicy Bypass -File .\\scripts\\build-win-exe.ps1",
    "dev": "tsx src/index.ts",
    "mcp": "tsx src/index.ts mcp-server",
    "link:global": "powershell -ExecutionPolicy Bypass -File .\\scripts\\install-global-dev.ps1",
    "test": "vitest run",
    "lint": "eslint .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "commander": "^14.0.1",
    "fast-xml-parser": "^5.3.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^24.6.0",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "eslint": "^9.36.0",
    "esbuild": "^0.25.9",
    "pkg": "^5.8.1",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
